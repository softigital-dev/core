{
    "name": "softigital-dev/core",
    "description": "some of our usefull things that is needed in any laravel project",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "SoftigitalDev\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SoftigitalDev\\Core\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "youssef ehab",
            "email": "youssef.ehab@softigital.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/process": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "SoftigitalDev\\Core\\Providers\\CoreServiceProvider"
            ]
        }
    }
}
